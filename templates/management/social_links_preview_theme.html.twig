{# Overrides SocialLinksPreviewType's widget - registered via Crud::addFormTheme() in
   SocialLinksCrudController. The link list itself is static (shows the last saved state, not a live
   preview of unsaved edits to the "links" collection above - see SocialLinksPreviewType for why), but
   unlike that, "icon style"/"display label" ARE live: assets/js/social-links-preview.js just swaps the
   list's ".social-links--minimal"/"--colored" class and the label's visibility, on page load and on
   every change - no re-render needed, since both styles share the same icon (see
   SocialLinkExtension::getSocialLinkIcon()) and CSS (sass/_social.scss) does the recoloring. #}
{% block social_links_preview_widget %}
    {# Scoped to SocialBundle's own compiled stylesheet only ("social-links*" classes don't collide with
       EasyAdmin's Bootstrap/AdminLTE ones) - never load the app's main front-end stylesheet here, see
       c975L/UiBundle's README ("Automatic CSS injection for EasyAdmin management pages") #}
    {# Root-relative, unlike the front-end's bundle_stylesheets() (StylesheetProvider::getStylesheets()):
       the front-end layout resolves those against a <base href> pointing at the domain root, but EasyAdmin
       pages live several segments deep (e.g. /management/social/social-links/1/edit) with no such
       <base> tag, so a bare "bundles/..." path would 404 against the current page's own URL instead #}
    <link rel="stylesheet" href="/bundles/c975lsocial/css/styles.min.css">
    <div id="sl-links-preview">
        {% if links is not empty %}
            <ul class="social-links social-links--{{ icon_style }}" data-social-links-preview-list>
                {% for link in links %}
                    {% set label = link.network is not empty ? link.network|capitalize : link.customLabel %}
                    {% set icon = link.network is not empty ? social_link_icon(link.network) : link.customIcon %}
                    <li class="social-link social-link--{{ link.network is not empty ? link.network : 'other' }}">
                        <a href="{{ link.url }}" aria-label="{{ label }}" target="_blank" rel="noopener">
                            {% if icon is not empty %}
                                <twig:c975LUi:Image:Icon src="{{ icon }}" width="32" height="32" class="social-link-icon" title="{{ label }}" />
                            {% endif %}
                            <span class="social-link-label"{% if not display_label %} hidden{% endif %}>{{ label }}</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}
