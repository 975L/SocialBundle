{# Adapter for the dynamic Block system - "data.links" (see SocialLinksType) is spread as "links" #}
{% if links is defined and links is not empty %}
    <ul class="social-links">
        {% for link in links %}
            <li class="social-link">
                <a href="{{ link.url }}" aria-label="{{ link.label }}" target="_blank" rel="noopener">
                    {% if link.icon is not empty %}
                        <twig:c975LUi:Image:Icon src="{{ link.icon }}" width="24" height="24" alt="{{ link.label }}" />
                    {% endif %}
                    {{ link.label }}
                </a>
            </li>
        {% endfor %}
    </ul>
{% endif %}
